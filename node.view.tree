		highlight <= highlight \
		uri_resolve* <= uri_resolve* \
		text <= grid_cell_text* \
	- \Lines
	String* $mol_dimmer
		dom_name \span
		needle <= highlight \
		haystack <= line_text* \
	Span* $mol_text_span
		dom_name \span
		type <= line_type* \
		sub <= line_content* /
	Code_line* $mol_text_code_line
		numb_showed false
		highlight <= highlight \
		text <= line_text* \
		uri_resolve* <= uri_resolve* \
		syntax <= code_syntax null
	Link* $mol_link_iconed
		uri <= link_uri* \
		content <= line_content* /
	Link_http* $mol_link_iconed
		uri <= link_uri* \
		content / <= link_host* \
	Embed* $mol_embed_any
		uri <= link_uri* \
		title <= line_text* \
	- \Spoilers
	Spoiler* $mol_expander
		label /
			<= Spoiler_label* $mol_text
				text <= spoiler_label* \
		content /
			<= Spoiler_content* $mol_text
				text <= spoiler_content* \

$mol_text_header $mol_paragraph
	level 1
	sub /
		<= Link $mol_link
			arg <= arg *
			hint @ \Permalink to this section
			sub <= content /

$mol_text_span $mol_paragraph
	dom_name \span
	attr *
		^
		mol_text_type <= type \

$mol_text_list $mol_text
	auto_scroll null
	attr *
		^
		mol_text_list_type <= type \
	Paragraph* $mol_text_list_item
		index <= item_index*
		sub <= block_content*

$mol_text_list_item $mol_paragraph
	attr *
		^
		mol_text_list_item_index <= index 0

$bog_docs_editor $mol_view
	sub /
		<= Code $mol_textarea
			hint \Write your view.tree code here...
			value? <=> source? \
		<= Preview $mol_text
			text <= preview_text \

$bog_docs_landing $mol_page
	title \The $mol Framework
	body /
		<= Hero $mol_view
			sub /
				<= Hero_title $mol_view
					sub /
						\The $mol Framework
				<= Hero_subtitle $mol_view
					sub /
						\Reactive, composable, and lightweight UI framework
				<= Hero_actions $mol_view
					sub /
						<= Get_started $mol_link
							arg *
								page \guide
							sub /
								\Get Started
						<= Play_link $mol_link
							arg *
								page \play
							sub /
								\Playground
		<= Props $mol_view
			sub /
				<= Prop_reactive $mol_view
					sub /
						<= Prop_reactive_icon $mol_view
							sub /
								\⚡
						<= Prop_reactive_title $mol_view
							sub /
								\Reactive
						<= Prop_reactive_text $mol_view
							sub /
								\Automatic dependency tracking with @$mol_mem. No manual subscriptions, no useEffect — state changes propagate instantly.
				<= Prop_composable $mol_view
					sub /
						<= Prop_composable_icon $mol_view
							sub /
								\🧩
						<= Prop_composable_title $mol_view
							sub /
								\Composable
						<= Prop_composable_text $mol_view
							sub /
								\Declarative view.tree syntax for building UIs. Components nest naturally with one-way and two-way bindings.
				<= Prop_lightweight $mol_view
					sub /
						<= Prop_lightweight_icon $mol_view
							sub /
								\🪶
						<= Prop_lightweight_title $mol_view
							sub /
								\Lightweight
						<= Prop_lightweight_text $mol_view
							sub /
								\~100KB bundle with routing, state management, and UI components included. 3x smaller than React+Redux.
		<= Demo $mol_view
			sub /
				<= Demo_title $mol_view
					sub /
						\Try It Live
				<= Demo_subtitle $mol_view
					sub /
						\Edit the view.tree code and see the transpiled result instantly
				<= Demo_editor $bog_docs_editor
					source? <=> demo_source? \
		<= Ecosystem $mol_view
			sub /
				<= Ecosystem_title $mol_view
					sub /
						\Ecosystem
				<= Ecosystem_links $mol_view
					sub /
						<= Link_mam $mol_link
							uri \https://github.com/hyoo-ru/mam
							target \_blank
							sub /
								\MAM
						<= Link_giper $mol_link
							uri \https://baza.hyoo.ru/
							target \_blank
							sub /
								\Giper Baza
						<= Link_components $mol_link
							uri \https://mol.hyoo.ru/
							target \_blank
							sub /
								\Components
						<= Link_tauri $mol_link
							uri \https://tauri.app/
							target \_blank
							sub /
								\Tauri
		<= Footer $mol_view
			sub /
				<= Footer_links $mol_view
					sub /
						<= Link_github $mol_link
							uri \https://github.com/hyoo-ru/mam
							target \_blank
							sub /
								\GitHub
						<= Link_docs $mol_link
							arg *
								page \guide
							sub /
								\Docs
						<= Link_community $mol_link
							uri \https://t.me/nicehero
							target \_blank
							sub /
								\Community

$mol_button_major $mol_button_minor
	theme \$mol_theme_base

$bog_docs_guide_lesson $mol_page
	title <= lesson_title \Lesson
	lesson_id \
	initial_code \
	solution \
	hints /string
	body /
		<= Explanation $mol_text
			text <= explanation \
		<= Code_editor $bog_docs_editor
			source? <=> code? \
		<= Task_section $mol_view
			sub /
				<= Task_description $mol_text
					text <= task_text \
				<= Actions $mol_view
					sub /
						<= Check_button $mol_button_major
							click? <=> check? null
							sub /
								\Check
						<= Check_result $mol_view
							sub <= check_result_sub /
						<= Hint_button $mol_button_minor
							click? <=> show_hint? null
							sub /
								\Hint
						<= Solution_button $mol_button_minor
							click? <=> show_solution? null
							sub /
								\Solution
						<= Next_button $mol_link
							arg <= next_arg *
							sub /
								\Next
	Check_success $mol_view
		sub / \Correct!
	Check_error $mol_view
		sub / \Try again

$bog_docs_guide $mol_page
	title \Docs
	tools /
		<= Prev_link $mol_link
			arg <= prev_arg *
			sub /
				\‹
		<= Progress $mol_view
			sub / <= progress_text \
		<= Next_link $mol_link
			arg <= next_arg *
			sub /
				\›
		<= Reset_button $mol_button_minor
			click? <=> reset_progress? null
			sub /
				\Reset
	body /
		<= Current_lesson $bog_docs_guide_lesson
			lesson_title <= current_title \
			explanation <= current_explanation \
			task_text <= current_task \
			initial_code <= current_initial_code \
			solution <= current_solution \
			lesson_id <= current_lesson_id \

$bog_docs_play $mol_page
	title \Playground
	tools /
		<= Preset_hello $mol_button_minor
			title \Hello World
			click? <=> preset_hello? null
		<= Preset_counter $mol_button_minor
			title \Counter
			click? <=> preset_counter? null
		<= Preset_todo $mol_button_minor
			title \Todo List
			click? <=> preset_todo? null
		<= Share_btn $mol_button_minor
			title \Share
			click? <=> share? null
	body /
		<= Code_editor $bog_docs_editor
			source? <=> source? \

$bog_docs_app $mol_book2_catalog
	plugins /
		<= Theme_auto $bog_theme_auto
			themes /
				\$mol_theme_calm_light
				\$mol_theme_calm_dark
			theme_light \$mol_theme_calm_light
			theme_dark \$mol_theme_calm_dark
	param \page
	menu_title \$mol Docs
	menu_tools /
		<= Theme_toggle $bog_theme_toggle
			theme_auto <= Theme_auto
		<= Lang_en $mol_button_minor
			title \EN
			click? <=> switch_en? null
		<= Lang_ru $mol_button_minor
			title \RU
			click? <=> switch_ru? null
	menu_foot /
		<= Github_link $mol_link
			uri \https://github.com/hyoo-ru/mam
			target \_blank
			sub /
				\GitHub
	spreads *
		landing <= Landing $bog_docs_landing
			tools /
				<= Spread_close
		guide <= Guide $bog_docs_guide
			tools /
				<= Spread_close
		play <= Play $bog_docs_play
			tools /
				<= Spread_close
